{
  "name": "kn-lan-chat",
  "version": "0.0.1",
  "description": "A CLI application for TCP chat server and client",
  "type": "module",
  "bin": {
    "klcs": "./dist/server/tcps.js",
    "klcc": "./dist/client/tcpc.js"
  },
  "files": [
    "dist/**/*.js"
  ],
  "scripts": {
    "server": "tsx ./src/server/tcps.js",
    "client": "tsx ./src/client/tcpc.js",
    "build": "tsc"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0"
  },
  "keywords": [
    "tcp",
    "chat",
    "cli",
    "server",
    "client"
  ],
  "author": "karan",
  "license": "MIT"
}
