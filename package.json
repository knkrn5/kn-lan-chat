{
  "name": "kn-lan-chat",
  "version": "0.0.2",
  "description": "TCP LAN chat CLI for server/client messaging with private chat, broadcast, and IP ban management",
  "type": "module",
  "bin": {
    "klcs": "dist/server/tcps.js",
    "klcc": "dist/client/tcpc.js"
  },
  "main": "dist/server/tcps.js",
  "files": [
    "dist/**/*.js"
  ],
  "scripts": {
    "clean": "node -e \"const fs=require('node:fs');fs.rmSync('dist',{recursive:true,force:true});\"",
    "server": "tsx ./src/server/tcps.ts",
    "client": "tsx ./src/client/tcpc.ts",
    "build": "npm run clean && tsc"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0"
  },
  "keywords": [
    "tcp",
    "chat",
    "lan",
    "cli",
    "server",
    "client",
    "messaging",
    "socket",
    "nodejs",
    "terminal",
    "private-message",
    "broadcast"
  ],
  "author": {
    "name": "knkrn5"
  },
  "homepage": "https://github.com/knkrn5/kn-lan-chat#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/knkrn5/kn-lan-chat.git"
  },
  "bugs": {
    "url": "https://github.com/knkrn5/kn-lan-chat/issues"
  },
  "license": "MIT"
}
